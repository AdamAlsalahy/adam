# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here-change-this-in-production

# Database
# Koyeb: استخدم DATABASE_URL مع قاعدة بيانات PostgreSQL
DATABASE_URL=postgres://user:password@host:5432/dbname

# Security
ALLOWED_HOSTS=*.koyeb.app,yourdomain.com

# Koyeb: أضف نطاق تطبيقك هنا
CSRF_TRUSTED_ORIGINS=https://your-app-name.koyeb.app,https://yourdomain.com

# Email Settings (Optional)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Site Settings
SITE_NAME=مؤسسة نجمة الإبداع
SITE_DOMAIN=https://yourdomain.com
